NEXT_PUBLIC_API_KEY=your_key_here
DATABASE_URL=your_url_here

# NextAuth configuration
# For production, set to your domain (e.g., https://www.tokensense-ai.com)
# For local development, set to http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Generate a random secret (e.g., openssl rand -base64 32)
NEXTAUTH_SECRET=797fb5806df45030764db9cb8b7c2b520748fcbaab75061e3f7f06ea22ac2f88

# Google OAuth Credentials
# Obtain these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_id_here
GOOGLE_CLIENT_SECRET=your_google_secret_here

# GitHub OAuth Credentials
# Obtain these from: https://github.com/settings/developers
GITHUB_ID=your_github_id_here
GITHUB_SECRET=your_github_secret_here
