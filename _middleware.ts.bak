import createMiddleware from "next-intl/middleware";
import { routing } from "./src/i18n/routing";

export default createMiddleware(routing);

export const config = {
  // Match all pathnames except for:
  // - API routes
  // - _next internals
  // - Static files (manifest, robots, sitemap, etc)
  matcher: [
    "/((?!api|_next|_vercel|.*\\..*|manifest\\.json|robots\\.txt|sitemap\\.xml|sw\\.js|favicon\\.png|icon\\.svg).*)",
  ],
};
